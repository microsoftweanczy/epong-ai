# ─────────────────────────────────────────────────────────────
# Epong AI — Environment Variables
# Copy to `.env.local` and fill in your keys.
# ─────────────────────────────────────────────────────────────

# ── Supabase (backend + auth) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── GLM API (primary text AI — via DashScope/Qwen Cloud) ────
# If omitted, a built-in fallback key is used.
# Default model: qwen3.6-flash (fast + current)
GLM_API_KEY=
GLM_MODEL=qwen3.6-flash
GLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── OpenRouter API (optional fallback) ───────────────────────
# IMPORTANT: OpenRouter key format is sk-or-v1-... (NOT the GLM key!)
# Get one at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-your-real-openrouter-key
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Qwen Image API (image generation — z-image-turbo) ───────
# Used by /api/generate-image. Get a key at https://dashscope.aliyuncs.com
# If omitted, a built-in fallback key is used.
QWEN_IMAGE_API_KEY=

