# ─────────────────────────────────────────────────────────────
# Epong AI — Personal AI Chatbot · Environment Variables
# Copy this file to `.env.local` and fill in your keys.
# On Vercel, add the same variables in Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# ── Supabase (backend for chat history + auth) ────────────────
# Create a free project at https://supabase.com
# Project Settings → API → copy URL + anon public key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── OpenRouter API (primary AI provider) ──────────────────────
# Get a free key at https://openrouter.ai/keys
# Gives access to 100+ models (GPT-OSS, Llama, Gemini, Qwen, etc.)
OPENROUTER_API_KEY=
# Optional: model (default: openai/gpt-oss-120b:free). Browse at openrouter.ai/models
OPENROUTER_MODEL=openai/gpt-oss-120b:free
