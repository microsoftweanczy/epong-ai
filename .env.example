# ─────────────────────────────────────────────────────────────
# ManggarAI — Environment Variables
# Copy to `.env.local` and fill in your keys.
# ─────────────────────────────────────────────────────────────

# ── GitHub Models (primary text AI — GPT-4o-mini, DeepSeek, Llama) ──
# Get a token at https://github.com/settings/tokens (classic, no scope needed)
GITHUB_TOKEN=

# ── Tavily AI (web search — super accurate for realtime data) ──
# Get a free key (1,000 searches/month) at https://tavily.com
# If omitted, falls back to z-ai SDK built-in search
TAVILY_API_KEY=

# ── Supabase (backend + auth) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── GLM API (fallback text AI — via DashScope) ───────────────
GLM_API_KEY=
GLM_MODEL=glm-5.1
GLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── OpenRouter API (optional fallback) ───────────────────────
# OPENROUTER_API_KEY=sk-or-v1-your-key
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Hugging Face (image generation — FLUX.1-schnell) ────────
# Optional — works without token (rate-limited). Get at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token

