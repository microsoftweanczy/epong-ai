# ─────────────────────────────────────────────────────────────
# Aria — Personal AI Chatbot · Environment Variables
# Copy this file to `.env.local` and fill in your keys.
# On Vercel, add the same variables in Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# ── Supabase (backend for chat history) ───────────────────────
# Create a free project at https://supabase.com
# Project Settings → API → copy URL + anon public key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── GLM API (AI model) ────────────────────────────────────────
# Get a free key at https://open.bigmodel.cn
# Without GLM_API_KEY the app falls back to the preview SDK.
GLM_API_KEY=
# Optional: model name (default: glm-4.5-flash, free tier)
GLM_MODEL=glm-4.5-flash
# Optional: base URL (default: OpenAI-compatible Zhipu endpoint)
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ── OpenRouter API (second AI provider — smart fallback) ──────
# Get a free key at https://openrouter.ai/keys
# Gives access to many models (Llama, Gemini, Qwen, etc.)
# When set, the app smart-switches: GLM -> OpenRouter -> built-in SDK
OPENROUTER_API_KEY=
# Optional: model (default: free Llama 3.3 70B). Browse models at openrouter.ai/models
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
